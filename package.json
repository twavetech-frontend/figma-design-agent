{
  "name": "figma-design-agent",
  "version": "0.1.0",
  "description": "Figma Design Agent - Electron desktop app for fast AI-powered design generation",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run build:main && npm run build:renderer && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder",
    "bridge": "node out/bridge/index.js",
    "postinstall": "node scripts/patch-hono-mcp.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/sdk": "^0.52.0",
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@untitledui/icons": "^0.0.21",
    "electron-store": "^10.0.0",
    "hono": "^4.7.0",
    "jsonrepair": "^3.12.0",
    "sharp": "^0.33.5",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "yoga-layout": "^3.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.0",
    "vitest": "^4.1.0"
  }
}
