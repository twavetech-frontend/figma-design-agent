{
  "name": "figma-design-agent",
  "version": "0.1.0",
  "description": "Figma Design Agent - bridge server (WebSocket + MCP HTTP) for AI-powered Figma design generation",
  "main": "out/bridge/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "bridge": "node out/bridge/index.js",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "setup:mac": "bash scripts/setup-mac.sh",
    "postinstall": "node scripts/patch-hono-mcp.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.3",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@untitledui/icons": "^0.0.21",
    "hono": "^4.7.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "yoga-layout": "^3.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
