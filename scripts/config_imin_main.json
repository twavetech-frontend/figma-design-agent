          "name": "Task Item 3", "type": "frame", "layoutSizingHorizontal": "FILL", "height": 52,
          "autoLayout": { "layoutMode": "HORIZONTAL", "counterAxisAlignItems": "CENTER", "itemSpacing": 12, "paddingTop": 14, "paddingBottom": 14 },
          "children": [
