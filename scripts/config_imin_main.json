            { "name": "Stage Amount", "type": "text", "text": "260만원", "fontSize": 22, "fontWeight": 700, "fontColor": "$token(fg-primary)" },
            {
              "name": "Stage Info Row", "type": "frame", "layoutSizingHorizontal": "FILL",
              "autoLayout": { "layoutMode": "HORIZONTAL", "primaryAxisAlignItems": "SPACE_BETWEEN", "counterAxisAlignItems": "CENTER" },
