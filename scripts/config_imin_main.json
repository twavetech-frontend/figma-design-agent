                { "name": "Fun Title 1", "type": "text", "text": "랜덤박스", "fontSize": 16, "fontWeight": 700, "fontColor": "$token(fg-primary)" },
                { "name": "Fun Desc 1", "type": "text", "text": "매일 선물이 쏟아져요", "fontSize": 13, "fontWeight": 400, "fontColor": "$token(fg-tertiary)" }
              ]
            },
            {
              "name": "Fun Card 2", "type": "frame", "layoutSizingHorizontal": "FILL",
              "autoLayout": { "layoutMode": "VERTICAL", "paddingTop": 16, "paddingBottom": 16, "paddingLeft": 16, "paddingRight": 16, "itemSpacing": 8 },
              "fill": "$token(bg-secondary)", "cornerRadius": 16,
              "children": [
                { "name": "Fun Icon 2", "type": "frame", "width": 32, "height": 32, "cornerRadius": 0, "imageGen": { "prompt": "3D rendered shopping bag with gift ribbon, teal and coral colors, vivid glossy style. Chunky compact form. Pure white background. No text. No shadow.", "isHero": false, "width": 32, "height": 32 } },
                { "name": "Fun Title 2", "type": "text", "text": "기프트샵", "fontSize": 16, "fontWeight": 700, "fontColor": "$token(fg-primary)" },
                { "name": "Fun Desc 2", "type": "text", "text": "포인트로 기프티콘 교환", "fontSize": 13, "fontWeight": 400, "fontColor": "$token(fg-tertiary)" }
              ]
