{
  "rootName": "imin Main Home",
  "width": 393,
  "height": 1800,
  "fill": "$token(bg-primary)",
  "sections": [
    "NavBar",
    "Ribbon",
    "Hero",
    "custom",
    "custom",
    "custom",
    "custom",
    "FAB",
    "TabBar"
  ],
  "variables": {
    "Ribbon": {
      "text": "누적 거래 3,191,399건"
    },
    "Hero": {
      "banners": [
        {
          "tag": "EVENT",
          "title": "친구 초대하면\n최대 수익 100%",
          "imagePrompt": "3D rendered gift box and gold coins floating with confetti, objects on the RIGHT side only, LEFT half must be empty solid color. Rich violet purple gradient background (#6938EF to #7C5CFC). Soft matte finish, rounded clay-like proportions. No text. No shadow."
        },
        {
          "tag": "PROMOTION",
          "title": "화장품 프로모션\n뷰티 스테이지 오픈",
          "imagePrompt": "3D rendered cosmetics bottles and beauty products floating, objects on the RIGHT side only, LEFT half must be empty solid color. Soft pink gradient background (#FF6B9D to #C084FC). Soft matte finish, clay-like proportions. No text. No shadow."
        },
        {
          "tag": "NEW",
          "title": "스테이지 목돈\n계산기 출시",
          "imagePrompt": "3D rendered calculator and stacked coins with sparkles, objects on the RIGHT side only, LEFT half must be empty solid color. Deep teal gradient background (#0D9488 to #2DD4BF). Soft matte finish, rounded proportions. No text. No shadow."
        }
      ]
    },
    "FAB": {
      "label": "마이 월렛",
      "icon": "wallet-02"
    },
    "TabBar": {
      "activeTab": "홈"
    }
  },
  "customSections": [
    {
      "name": "Recommended Stages",
      "type": "frame",
      "layoutSizingHorizontal": "FILL",
      "autoLayout": {
        "layoutMode": "VERTICAL",
        "paddingTop": 24,
        "paddingBottom": 24,
        "paddingLeft": 20,
        "paddingRight": 20,
        "itemSpacing": 16
      },
      "children": [
        {
          "name": "Section Header",
          "type": "frame",
          "layoutSizingHorizontal": "FILL",
          "autoLayout": { "layoutMode": "HORIZONTAL", "primaryAxisAlignItems": "SPACE_BETWEEN", "counterAxisAlignItems": "CENTER" },
          "children": [
            { "name": "Section Title", "type": "text", "text": "추천! 스테이지", "fontSize": 20, "fontWeight": 700, "fontColor": "$token(fg-primary)" },
            { "name": "View All", "type": "text", "text": "전체보기", "fontSize": 14, "fontWeight": 500, "fontColor": "$token(fg-tertiary)" }
          ]
        },
        {
          "name": "Tab Row",
          "type": "frame",
          "layoutSizingHorizontal": "FILL",
          "autoLayout": { "layoutMode": "HORIZONTAL", "itemSpacing": 8 },
          "stroke": "$token(border-secondary)",
          "strokeWeight": 1, "strokeTopWeight": 0, "strokeBottomWeight": 1, "strokeLeftWeight": 0, "strokeRightWeight": 0,
          "children": [
            {
              "name": "Tab Active",
              "type": "frame",
              "autoLayout": { "layoutMode": "VERTICAL", "paddingTop": 4, "paddingBottom": 0, "paddingLeft": 4, "paddingRight": 4, "itemSpacing": 8 },
              "children": [
                { "name": "Tab Label Active", "type": "text", "text": "빠른 시작", "fontSize": 14, "fontWeight": 600, "fontColor": "$token(fg-brand-primary)" },
                { "name": "Underline Bar", "type": "frame", "height": 2, "layoutSizingHorizontal": "FILL", "fill": "$token(bg-brand-solid)" }
              ]
            },
            {
              "name": "Tab Inactive",
              "type": "frame",
              "layoutSizingVertical": "FILL",
              "autoLayout": { "layoutMode": "VERTICAL", "paddingTop": 4, "paddingBottom": 0, "paddingLeft": 4, "paddingRight": 4 },
