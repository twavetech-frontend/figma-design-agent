    {
      "name": "Calculator Banner",
      "type": "frame",
      "layoutSizingHorizontal": "FILL",
      "autoLayout": { "layoutMode": "HORIZONTAL", "primaryAxisAlignItems": "SPACE_BETWEEN", "counterAxisAlignItems": "CENTER", "paddingTop": 16, "paddingBottom": 16, "paddingLeft": 20, "paddingRight": 20, "itemSpacing": 16 },
