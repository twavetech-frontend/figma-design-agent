              "name": "Stage Info Row", "type": "frame", "layoutSizingHorizontal": "FILL",
              "autoLayout": { "layoutMode": "HORIZONTAL", "primaryAxisAlignItems": "SPACE_BETWEEN", "counterAxisAlignItems": "CENTER" },
              "children": [
                { "name": "Stage Details", "type": "text", "text": "연 4.8%  ·  기프티콘 5,000원", "fontSize": 14, "fontWeight": 500, "fontColor": "$token(fg-secondary)" },
                { "name": "Bookmark Icon", "type": "icon", "iconName": "bookmark", "size": 20, "iconColor": "$token(fg-quaternary)" }
              ]
            }
          ]
        }
      ]
