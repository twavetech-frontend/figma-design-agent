            {
              "name": "Stage Tag", "type": "frame", "layoutSizingHorizontal": "HUG",
              "autoLayout": { "layoutMode": "HORIZONTAL", "paddingTop": 4, "paddingBottom": 4, "paddingLeft": 8, "paddingRight": 8 },
