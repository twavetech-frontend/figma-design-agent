            { "name": "Banner Subtitle", "type": "text", "text": "나에게 맞는 이익을 계산해 보세요", "fontSize": 13, "fontWeight": 400, "fontColor": "$token(fg-tertiary)" }
          ]
        },
        { "name": "Banner Chevron", "type": "icon", "iconName": "chevron-right", "size": 20, "iconColor": "$token(fg-quaternary)" }
      ]
