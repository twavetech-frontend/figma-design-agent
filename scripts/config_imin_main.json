            { "name": "Task Text 3", "type": "text", "text": "포인트 충전소", "fontSize": 16, "fontWeight": 500, "fontColor": "$token(fg-primary)" },
            { "name": "Task Chevron 3", "type": "icon", "iconName": "chevron-right", "size": 20, "iconColor": "$token(fg-quaternary)" }
          ]
        }
