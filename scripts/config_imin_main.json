                { "name": "Stage Details", "type": "text", "text": "연 5.2%  ·  포인트 3,000P", "fontSize": 14, "fontWeight": 500, "fontColor": "$token(fg-secondary)" },
                { "name": "Bookmark Icon", "type": "icon", "iconName": "bookmark", "size": 20, "iconColor": "$token(fg-quaternary)" }
              ]
            }
          ]
        },
        {
          "name": "Stage Card 2",
          "type": "frame",
          "layoutSizingHorizontal": "FILL",
          "autoLayout": { "layoutMode": "VERTICAL", "paddingTop": 16, "paddingBottom": 16, "paddingLeft": 16, "paddingRight": 16, "itemSpacing": 8 },
          "fill": "$token(bg-secondary)",
          "cornerRadius": 16,
          "children": [
            {
              "name": "Stage Tag", "type": "frame", "layoutSizingHorizontal": "HUG",
              "autoLayout": { "layoutMode": "HORIZONTAL", "paddingTop": 4, "paddingBottom": 4, "paddingLeft": 8, "paddingRight": 8 },
              "fill": "$token(bg-success-primary)", "cornerRadius": 4,
              "children": [{ "name": "Tag Text", "type": "text", "text": "기프티콘", "fontSize": 12, "fontWeight": 600, "fontColor": "$token(fg-success-primary)" }]
