    {
      "name": "Fun Section",
      "type": "frame",
      "layoutSizingHorizontal": "FILL",
      "autoLayout": { "layoutMode": "VERTICAL", "paddingTop": 24, "paddingBottom": 24, "paddingLeft": 20, "paddingRight": 20, "itemSpacing": 12 },
