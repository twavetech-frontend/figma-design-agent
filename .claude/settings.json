{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "mcp__figma-tools",
      "mcp__paper",
      "mcp__pencil"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "figma-tools"
  ],
  "env": {
    "FIGMA_MCP_SKIP_ENHANCE": "1",
    "FIGMA_MCP_REQUEST_TIMEOUT": "600"
  }
}
